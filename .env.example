SH_CLIENT_ID=your-copernicus-oauth-client-id
SH_CLIENT_SECRET=your-copernicus-oauth-client-secret

# Persistent NDVI raster/metadata cache (db_cache.py) - own schema/credentials in the same
# Postgres instance kret already uses, not kret's own farming_db tables/user. Leave
# LOPATA_DB_ENABLED unset/false to keep the old in-memory-only cache behavior.
LOPATA_DB_ENABLED=false
LOPATA_DB_HOST=
LOPATA_DB_PORT=5432
LOPATA_DB_NAME=
LOPATA_DB_SCHEMA=lopata
LOPATA_DB_USER=
LOPATA_DB_PASSWORD=
